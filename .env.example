# Required — Get a free Gemini key at https://aistudio.google.com/apikey
LLM_API_KEY=your-api-key-here

# Optional — defaults to Gemini free tier
# LLM_MODEL=gemini-2.0-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# To use Groq instead (free Llama 3.3 70B):
# LLM_API_KEY=gsk_your-groq-key
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1

# To use OpenAI instead, set:
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# ── Fallback LLM (used when primary hits rate limits) ────────────────────────
# Cerebras free tier (fast Llama 3.3 70B): https://cloud.cerebras.ai/
# LLM_FALLBACK_API_KEY=your-cerebras-key
# LLM_FALLBACK_MODEL=llama-3.3-70b
# LLM_FALLBACK_BASE_URL=https://api.cerebras.ai/v1

# Google Gemini free tier: https://aistudio.google.com/apikey
# LLM_FALLBACK_API_KEY=your-gemini-key
# LLM_FALLBACK_MODEL=gemini-2.0-flash
# LLM_FALLBACK_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Optional — only needed if running outside GitHub Actions
# GITHUB_TOKEN=ghp_...
